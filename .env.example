# Cf. L026 Gestion de la configuration — aucune valeur réelle ne doit être committée.
# Copier ce fichier vers .env et renseigner les valeurs réelles (jamais versionnées).

APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# Cf. L011 §16.5 — rôle applicatif turfia_app (lecture/écriture métier et analyses)
DATABASE_URL=postgresql://turfia_app:changeme@localhost:5432/turfia

SECRET_KEY=changeme
